# Provider IA : stub | gemini | groq
AI_PROVIDER=stub

# Gemini (gratuit - 1500 req/jour)
# Clé sur : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Groq (gratuit - ~14000 req/jour)
# Clé sur : https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# Jira Cloud
JIRA_BASE_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token-here
JIRA_PROJECT_KEY=PROJ

# Mode dry-run (true = aucun appel HTTP vers Jira)
DRY_RUN=true

# Probabilité d'ajouter un commentaire sur les transitions (0.0 à 1.0)
COMMENT_ON_TRANSITION=0.30

# Nombre d'événements par run
EVENTS_PER_RUN=3

# Projets à simuler — séparés par des virgules
JIRA_PROJECT_KEYS=POT

# Bootstrap automatique avant chaque run (true = rafraîchit state.json depuis Jira)
AUTO_BOOTSTRAP=true

# Seuils de maintien du backlog
MIN_TODO_TICKETS=10
MIN_ACTIVE_EPICS=10

# Rééquilibrage automatique avant chaque run (true/false)
AUTO_REPLENISH=true

# Probabilité d'ajouter un commentaire IA lors d'un changement de statut (0.0 à 1.0)
# BLOCKED : toujours 1.0 (ignoré pour ce statut)
COMMENT_ON_TRANSITION=0.30

# Probabilité d'ajouter un commentaire IA lors d'un changement de statut (0.0 à 1.0)
# BLOCKED : toujours 1.0 (ignoré pour ce statut)
COMMENT_ON_TRANSITION=0.30
